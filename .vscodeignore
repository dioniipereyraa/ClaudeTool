# Source — only the esbuild bundle under dist/extension ships
src/**
tests/**
scripts/**
node_modules/**
coverage/**
.vitest-cache/**

# Marketplace icon: ship PNG, not SVG. The activity-bar icon
# (sidebar-icon.svg) MUST ship — it's referenced from package.json
# contributes.viewsContainers and VS Code resolves it at runtime.
assets/*.svg
!assets/sidebar-icon.svg

# Build tooling
tsconfig*.json
esbuild.config.*
eslint.config.*
vitest.config.*
.prettierignore
.prettierrc*

# Git / editor / CI
.git/**
.github/**
.vscode/**
.gitignore
.gitattributes
.npmrc

# Project meta that doesn't belong in the extension bundle
DEVLOG.md
ROADMAP.md
README.vsix.md
.claude/**
.exportal/**
exports/**
chrome/**
docs/**
design-cds/**

# Everything under dist/ except the extension bundle itself
dist/index.*
dist/cli/**
dist/core/**
dist/formatters/**
dist/importers/**
dist/redactors/**
dist/extension/*.map

# Package-local files
*.vsix
exportal-companion-*.zip
*.log
*.tsbuildinfo
package-lock.json

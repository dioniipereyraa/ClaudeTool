{
  "manifest_version": 3,
  "name": "Exportal Companion",
  "version": "0.2.2",
  "description": "Exportá chats de claude.ai a VS Code con un click. Requiere la extensión Exportal en VS Code — emparejá con el token que aparece ahí (ver Opciones).",
  "minimum_chrome_version": "116",
  "icons": {
    "128": "icon-128.png"
  },
  "action": {
    "default_icon": "icon-128.png",
    "default_title": "Exportal Companion"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["storage", "downloads"],
  "host_permissions": ["http://127.0.0.1/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["pure.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}

{
  "name": "exportal",
  "displayName": "Exportal",
  "version": "0.0.0",
  "description": "Bridge between claude.ai and Claude Code — export Claude Code sessions to clean Markdown and import claude.ai exports as context.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Dionisio Pereyra Bocchio",
  "publisher": "dioniipereyraa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dioniipereyraa/ClaudeTool.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "claude-code", "anthropic", "export", "markdown"],
  "bin": {
    "exportal": "./dist/cli/index.js"
  },
  "main": "./dist/extension/extension.cjs",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "exportal.importFromZip",
        "title": "Exportal: Import claude.ai ZIP"
      }
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:extension",
    "build:extension": "node esbuild.config.mjs",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@types/vscode": "^1.116.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.25.12",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.4.2",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "jszip": "^3.10.1",
    "zod": "^4.3.6"
  }
}

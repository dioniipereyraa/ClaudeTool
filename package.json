{
  "name": "exportal",
  "displayName": "Exportal",
  "version": "0.8.2",
  "description": "%extension.description%",
  "l10n": "./l10n",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Dionisio Pereyra Bocchio",
  "publisher": "dioniipereyraa",
  "repository": {
    "type": "git",
    "url": "https://github.com/dioniipereyraa/ClaudeTool.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "export",
    "markdown"
  ],
  "bin": {
    "exportal": "./dist/cli/index.js"
  },
  "main": "./dist/extension/extension.cjs",
  "icon": "assets/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "exportal.importFromZip",
        "title": "%command.importFromZip.title%"
      },
      {
        "command": "exportal.showPairingInfo",
        "title": "%command.showPairingInfo.title%"
      },
      {
        "command": "exportal.sendSessionToClaudeAi",
        "title": "%command.sendSessionToClaudeAi.title%"
      },
      {
        "command": "exportal.importFromChatGptZip",
        "title": "%command.importFromChatGptZip.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "exportal.autoAttachToClaudeCode": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoAttachToClaudeCode.description%"
        },
        "exportal.alsoWriteJsonl": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.alsoWriteJsonl.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "exportal",
          "title": "Exportal",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "exportal": [
        {
          "type": "webview",
          "id": "exportal.controlPanel",
          "name": "Control Panel"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:extension",
    "build:extension": "node esbuild.config.mjs",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "package:vsix": "npm run build && node scripts/package-vsix.mjs",
    "package:chrome": "node scripts/package-chrome.mjs",
    "package:all": "npm run package:vsix && npm run package:chrome",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@types/vscode": "~1.85.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.4.2",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "jszip": "^3.10.1",
    "zod": "^4.3.6"
  }
}
